{
  "name": "celestial-app",
  "version": "0.1.0",
  "private": true,
  "description": "Celestial privacy browser shell (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:headless": "xvfb-run -a electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.celestial.browser",
    "productName": "Celestial",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      { "from": "../core", "to": "core" },
      { "from": "../requirements.txt", "to": "requirements.txt" },
      { "from": "../desktop/config", "to": "desktop/config" }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "publish": {
      "provider": "generic",
      "url": "REPLACE_ME_UPDATE_SERVER_URL"
    }
  }
}
